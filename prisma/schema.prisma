datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  password       String
  role           String         @default("EMPLOYEE") // ADMIN, DEPT_HEAD, EMPLOYEE
  photo          String?        // path to photo file
  gender         String?
  dob            String?

  // Department relationships
  departmentId   String?
  department     Department?    @relation("DeptMembers", fields: [departmentId], references: [id])
  managedDept    Department?    @relation("DeptHead")

  // Task relationships
  assignedTasks  Task[]         @relation("AssignedTo")
  createdTasks   Task[]         @relation("AssignedBy")
  taskUpdates    TaskUpdate[]

  // Attendance and other requests
  attendances    Attendance[]
  notifications  Notification[]
  leaveRequests  LeaveRequest[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  headId    String?  @unique
  head      User?    @relation("DeptHead", fields: [headId], references: [id], onDelete: SetNull)
  members   User[]   @relation("DeptMembers")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id           String        @id @default(uuid())
  title        String
  description  String
  status       String        @default("PENDING") // PENDING, IN_PROGRESS, REVIEW, COMPLETED
  priority     String        @default("MEDIUM") // LOW, MEDIUM, HIGH
  progress     Int           @default(0) // 0 to 100
  deadline     DateTime

  assignedToId String
  assignedTo   User          @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: Cascade)

  assignedById String
  assignedBy   User          @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)

  updates      TaskUpdate[]
  history      TaskHistory[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model TaskUpdate {
  id         String   @id @default(uuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId String
  employee   User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  comment    String
  proofFile  String?  // path to the uploaded file in public/uploads/
  progress   Int?     // snapshot of completion % at the time of this update
  createdAt  DateTime @default(now())
}

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  action    String   // e.g. "Task Created", "Status Changed to Review", "Task Approved"
  actorName String   // e.g. "John Doe"
  createdAt DateTime @default(now())
}

model Attendance {
  id         String    @id @default(uuid())
  employeeId String
  employee   User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  checkIn    DateTime
  checkOut   DateTime?
  status     String    @default("PRESENT") // PRESENT, LATE, HALF_DAY, ABSENT
  selfieUrl  String?   // path to selfie file in public/uploads/
  latitude   Float?
  longitude  Float?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "TASK_ASSIGNED", "LATE_ALERT", "LEAVE_STATUS", etc.
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LeaveRequest {
  id         String   @id @default(uuid())
  employeeId String
  employee   User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reason     String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Setting {
  id              String   @id @default("global_settings")
  officeStartTime String   @default("09:00") // HH:MM
  officeEndTime   String   @default("17:00") // HH:MM
  emailsEnabled   Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}
